# Copy to .env and fill in. .env is gitignored — never commit real keys.

# --- LLM (OpenAI-compatible Vultr Serverless Inference endpoint) ---
NVIDIA_API_KEY=vultr-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LLM_BASE_URL=https://api.vultrinference.com/v1
# Model id per spec section 3, currently served via Vultr Serverless Inference.
# Env-overridable if the endpoint ever needs a different slug. Verify the exact
# slug against GET {LLM_BASE_URL}/models before changing it.
LLM_MODEL=moonshotai/Kimi-K2.6

# --- LLM defaults (spec section 3) ---
LLM_TEMPERATURE=0.2
LLM_SEED=42
LLM_MAX_TOKENS=16384
# Generous ceiling, not an observed real cap (32 concurrent requests verified
# clean against this endpoint). Halve concurrency if 429s ever appear.
LLM_MAX_RPM=600
# Speed knob for reasoning models: "none" -> 0 reasoning tokens. Kimi-K2.6 is
# non-reasoning, so this is a harmless no-op today (the endpoint accepts it).
# WARNING: GLM-5.2-FP8 on this endpoint ignores this flag and reasons unbounded
# (single calls ran 10+ min in testing); it is not a drop-in for bulk work.
LLM_REASONING_EFFORT=none

# --- Tool-calling protocol: native | json ---
# Decided ONCE by scripts/smoke_llm.py -> data/smoke_llm_result.json (config.py
# prefers that file's `selected_tool_protocol`; this var is only the fallback
# if the smoke result is missing). Do NOT decide per call.
# Smoke test against Kimi-K2.6 (2026-07-05): native tool calling works cleanly,
# so the decided protocol is "native". (json_mode also works; streaming yields
# no text on this Kimi deployment but has no production caller.) Re-run the
# smoke test and update both this value and the committed result file if the
# endpoint's behavior changes.
TOOL_PROTOCOL=native

# --- Embeddings (local, spec section 3) ---
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Optional: cheaper/faster model for the Tier-2 LLM judges only (evals/judges.py).
# Unset -> judges use LLM_MODEL. Agent/baseline never read this.
# JUDGE_MODEL=deepseek-ai/DeepSeek-V4-Flash
