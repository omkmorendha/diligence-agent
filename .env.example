# Copy to .env and fill in. .env is gitignored — never commit real keys.

# --- LLM (OpenAI-compatible NVIDIA endpoint) ---
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LLM_BASE_URL=https://integrate.api.nvidia.com/v1
# Model id per spec section 3 (confirmed available on the NVIDIA catalog).
# Env-overridable if the endpoint ever needs a different slug.
LLM_MODEL=z-ai/glm-5.2

# --- LLM defaults (spec section 3) ---
LLM_TEMPERATURE=0.2
LLM_SEED=42
LLM_MAX_TOKENS=16384

# --- Tool-calling protocol: native | json ---
# Set from the smoke test result (data/smoke_llm_result.json). Do NOT decide per call.
TOOL_PROTOCOL=json

# --- Embeddings (local, spec section 3) ---
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
