# Copy to .env and fill in. .env is gitignored — never commit real keys.

# --- LLM (OpenAI-compatible Vultr Serverless Inference endpoint) ---
NVIDIA_API_KEY=vultr-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LLM_BASE_URL=https://api.vultrinference.com/v1
# Model id per spec section 3, currently served via Vultr Serverless Inference.
# Env-overridable if the endpoint ever needs a different slug.
LLM_MODEL=nvidia/Nemotron-3-Nano-Omni-30B-A3B-Reasoning-BF16

# --- LLM defaults (spec section 3) ---
LLM_TEMPERATURE=0.2
LLM_SEED=42
LLM_MAX_TOKENS=16384
# Generous ceiling, not an observed real cap (32 concurrent requests verified
# clean against this endpoint). Halve concurrency if 429s ever appear.
LLM_MAX_RPM=600
# Speed knob for high-volume, simple-output calls (classification/extraction/
# judging): "none" -> 0 reasoning tokens, ~2-3s/call. Leave unset to keep the
# model's default reasoning where answer quality depends on it (e.g. the agent
# loop answering hard multi-step financial questions).
LLM_REASONING_EFFORT=none

# --- Tool-calling protocol: native | json ---
# Decided ONCE by scripts/smoke_llm.py -> data/smoke_llm_result.json (config.py
# prefers that file's `selected_tool_protocol`; this var is only the fallback
# if the smoke result is missing). Do NOT decide per call.
# Step 0 smoke test against the current model (2026-07-04): native tool calling
# works cleanly, so the decided protocol is "native". Re-run the smoke test and
# update both this value and the committed result file if the endpoint's
# behavior changes.
TOOL_PROTOCOL=native

# --- Embeddings (local, spec section 3) ---
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
